          echo "PASS: Found $GPU_COUNT GPU(s)"
      - name: Verify GPU model
        run: |
          GPU_NAME=$(nvidia-smi --query-gpu=name --format=csv,noheader | head -1)
          echo "GPU: $GPU_NAME"
          if echo "$GPU_NAME" | grep -qi "t4"; then
            echo "PASS: GPU is T4"
