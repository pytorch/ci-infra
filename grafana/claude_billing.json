                {
                  "matcher": {
                    "id": "byName",
                    "options": "cost_usd"
                  },
                  "properties": [
                    {
                      "id": "unit",
                      "value": "currencyUSD"
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
