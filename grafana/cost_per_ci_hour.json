                "spec": {
                  "id": "groupBy",
                  "options": {
                    "fields": {
                      "Time": {
                        "aggregations": [],
                        "operation": "groupby"
                      },
                      "cost": {
                        "aggregations": [
                          "sum"
                        ],
                        "operation": "aggregate"
                      }
                    }
                  }
                }
              }
            ]
          }
        },
        "description": "Real EC2 spend from CloudWatch EstimatedCharges (AWS/Billing, ServiceName=AmazonEC2, Currency=USD) for the fbossci account. Cash-basis / unblended list price — NOT net-amortized (does not spread RI/Savings Plan amortization or apply credits). EstimatedCharges is cumulative month-to-date and resets to 0 at each month boundary; daily spend is reset-handled via IF(DIFF(m1) < 0, m1, DIFF(m1)). Daily values are bucketed to ISO weeks (Monday-start, UTC).",
        "id": 1,
        "links": [],
        "title": "Total EC2 Cost — fbossci (weekly)",
        "vizConfig": {
          "group": "barchart",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "color": {
                  "mode": "palette-classic"
                },
                "unit": "currencyUSD"
              },
              "overrides": []
            },
            "options": {
              "barWidth": 0.97,
              "groupWidth": 0.7,
              "legend": {
                "displayMode": "list",
                "placement": "bottom",
                "showLegend": true
              },
              "orientation": "vertical",
              "showValue": "auto",
              "stacking": "none",
              "xTickLabelRotation": -45
            }
          },
          "version": ""
        }
      }
    },
    "panel-2": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ceczcsck1b20wb"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "format": 2,
                      "rawSql": "SELECT toStartOfDay(started_at) AS Time, sum(dateDiff('second', started_at, completed_at))/3600 AS ci_hours FROM default.workflow_job WHERE repository_full_name = 'pytorch/pytorch' AND status = 'completed' AND completed_at > started_at AND started_at >= $__fromTime AND started_at <= $__toTime AND arrayExists(x -> startsWith(x, 'mt-') OR startsWith(x, 'linux.') OR startsWith(x, 'windows.'), labels) GROUP BY Time ORDER BY Time"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": [
              {
                "kind": "formatTime",
                "spec": {
                  "id": "formatTime",
                  "options": {
                    "outputFormat": "GGGG-[W]WW",
                    "timeField": "Time",
                    "timezone": "utc"
                  }
                }
              },
              {
                "kind": "groupBy",
                "spec": {
                  "id": "groupBy",
                  "options": {
                    "fields": {
                      "Time": {
                        "aggregations": [],
                        "operation": "groupby"
                      },
                      "ci_hours": {
                        "aggregations": [
                          "sum"
                        ],
                        "operation": "aggregate"
                      }
                    }
                  }
                }
              }
            ]
          }
        },
        "description": "Weekly CI hours for pytorch/pytorch on the meta fleet (runner labels prefixed mt-, linux., or windows.; excludes lf- / lf. LF runners and GitHub-hosted). Sum of completed-job durations (dateDiff started_at -> completed_at). Daily values are bucketed to ISO weeks (Monday-start, UTC).",
        "id": 2,
        "links": [],
        "title": "Total CI Hours — pytorch/pytorch meta fleet (weekly)",
        "vizConfig": {
          "group": "barchart",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "color": {
                  "mode": "palette-classic"
                },
                "unit": "h"
              },
              "overrides": []
            },
            "options": {
              "barWidth": 0.97,
              "groupWidth": 0.7,
              "legend": {
                "displayMode": "list",
