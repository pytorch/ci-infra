                        ]
                      },
                      "expression": "",
                      "id": "m1",
                      "matchExact": true,
                      "metricEditorMode": 0,
                      "metricName": "EstimatedCharges",
                      "metricQueryType": 0,
                      "namespace": "AWS/Billing",
                      "period": "86400",
                      "queryMode": "Metrics",
                      "region": "us-east-1",
                      "statistic": "Maximum"
