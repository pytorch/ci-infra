                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ffsb48gx9ph4wb"
                    },
                    "group": "cloudwatch",
                    "kind": "DataQuery",
                    "spec": {
                      "dimensions": {},
                      "expression": "IF(DIFF(m1) < 0, m1, DIFF(m1))",
                      "id": "e1",
                      "label": "cost",
                      "matchExact": true,
                      "metricEditorMode": 1,
                      "metricName": "",
                      "metricQueryType": 0,
                      "namespace": "",
                      "period": "",
                      "queryMode": "Metrics",
                      "region": "us-east-1",
                      "statistic": ""
                    },
                    "version": "v0"
                  },
                  "refId": "B"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ceczcsck1b20wb"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "format": 2,
                      "rawSql": "SELECT toStartOfDay(started_at) AS Time, sum(dateDiff('second', started_at, completed_at))/3600 AS ci_hours FROM default.workflow_job WHERE repository_full_name = 'pytorch/pytorch' AND status = 'completed' AND completed_at > started_at AND started_at >= $__fromTime AND started_at <= $__toTime AND arrayExists(x -> startsWith(x, 'mt-') OR startsWith(x, 'linux.') OR startsWith(x, 'windows.'), labels) GROUP BY Time ORDER BY Time"
                    },
                    "version": "v0"
                  },
                  "refId": "C"
                }
              }
            ],
            "queryOptions": {},
            "transformations": [
              {
                "kind": "joinByField",
                "spec": {
                  "id": "joinByField",
                  "options": {
                    "byField": "Time",
                    "mode": "outer"
                  }
                }
              },
              {
                "kind": "renameByRegex",
                "spec": {
                  "id": "renameByRegex",
                  "options": {
                    "regex": "^ci_hours.*$",
                    "renamePattern": "ci_hours"
                  }
                }
              },
              {
                "kind": "formatTime",
                "spec": {
                  "id": "formatTime",
                  "options": {
                    "outputFormat": "GGGG-[W]WW",
                    "timeField": "Time",
                    "timezone": "utc"
                  }
                }
              },
              {
                "kind": "groupBy",
                "spec": {
                  "id": "groupBy",
                  "options": {
                    "fields": {
                      "Time": {
                        "aggregations": [],
                        "operation": "groupby"
                      },
                      "ci_hours": {
                        "aggregations": [
                          "sum"
                        ],
                        "operation": "aggregate"
                      },
                      "cost": {
                        "aggregations": [
                          "sum"
                        ],
                        "operation": "aggregate"
                      }
                    }
                  }
                }
              },
              {
                "kind": "calculateField",
                "spec": {
                  "id": "calculateField",
                  "options": {
                    "alias": "cost_per_ci_hour",
                    "binary": {
                      "left": "cost (sum)",
                      "operator": "/",
                      "right": "ci_hours (sum)"
                    },
                    "mode": "binary",
                    "replaceFields": false
                  }
                }
              },
              {
                "kind": "filterFieldsByName",
                "spec": {
                  "id": "filterFieldsByName",
                  "options": {
                    "include": {
                      "names": [
                        "Time",
                        "cost_per_ci_hour"
                      ]
                    }
                  }
                }
              }
            ]
          }
        },
        "description": "Weekly real EC2 cost (CloudWatch EstimatedCharges, ServiceName=AmazonEC2, reset-handled) divided by meta-fleet CI hours for pytorch/pytorch. CloudWatch daily EC2 cost and ClickHouse daily CI-hours are outer-joined on the shared midnight-UTC day, bucketed to ISO weeks, then divided per week. The numerator is fbossci EC2 spend only (cash-basis / unblended), so this is EC2 cost amortized over meta-fleet CI-hours, not a full per-runner unit cost.",
        "id": 3,
        "links": [],
        "title": "EC2 Cost per CI-Hour (weekly)",
        "vizConfig": {
