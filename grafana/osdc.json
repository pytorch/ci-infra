    "panel-7": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "ceczcsck1b20wb"
                    },
                    "group": "grafana-clickhouse-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "editorType": "sql",
                      "format": 0,
                      "meta": {
                        "builderOptions": {
                          "columns": [],
                          "database": "",
                          "limit": 1000,
                          "mode": "list",
                          "queryType": "table",
                          "table": ""
                        }
                      },
                      "pluginVersion": "4.17.0",
                      "queryType": "timeseries",
                      "rawSql": "SELECT\n  toStartOfInterval(head_commit.timestamp, INTERVAL 5 MINUTE) AS bucket,\n  COUNT() AS pushes\nFROM default.push\nWHERE deleted = false\n  AND repository.full_name IN (${repository:singlequote})\n  AND $__timeFilter(head_commit.timestamp)\nGROUP BY bucket\nORDER BY bucket WITH FILL\n  FROM toStartOfInterval($__fromTime, INTERVAL 5 MINUTE)\n  TO toStartOfInterval($__toTime, INTERVAL 5 MINUTE)\n  STEP INTERVAL 5 MINUTE"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Count of GitHub push webhook events per 5-minute window for the selected repositories, across all refs (branches and tags). Branch-deletion pushes (deleted=true) are excluded. Note: bucketed by head_commit.timestamp (commit author time embedded in the push payload), not webhook receive time — rebased/amended commits can land in earlier buckets than when CI was actually triggered. PRs from forks are recorded against the fork's repository, not the upstream one.",
        "id": 7,
        "links": [],
        "title": "Push Events (per 5 min)",
